.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.logo-top {
  width: 72%;
  height: 28%;
  background: #FF6B8A;
  border-radius: 12rpx;
}
.logo-filling {
  width: 88%;
  height: 16%;
  background: #F5E6FF;
  border-radius: 8rpx;
}
.logo-bottom {
  width: 72%;
  height: 28%;
  background: #FF6B8A;
  border-radius: 12rpx;
  opacity: 0.7;
}