.rc-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  animation: fadeSlideIn 0.4s cubic-bezier(0.25,0.1,0.25,1) both;
}
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.rc-title-row {
  display: flex;
  align-items: flex-start;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 0.5rpx solid #F0F0F5;
  transition: background 0.15s;
}
.rc-title-row:active { background: #F9F9FB; border-radius: 12rpx; padding: 8rpx; margin-bottom: 16rpx; }
.rc-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.4;
}
.rc-copy {
  font-size: 24rpx;
  color: #FF6B8A;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 20rpx;
  margin-top: 6rpx;
}
.rc-body {
  transition: background 0.15s;
  border-radius: 16rpx;
}
.rc-body:active { background: #F9F9FB; }
.rc-content {
  font-size: 30rpx;
  color: #3A3A3C;
  line-height: 1.9;
  white-space: pre-line;
  display: block;
}
.rc-body-footer {
  margin-top: 28rpx;
  padding-top: 22rpx;
  border-top: 0.5rpx solid #F5F5F7;
}
.rc-hint { font-size: 24rpx; color: #C7C7CC; }

.rc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 0.5rpx solid #F5F5F7;
}
.rc-tag {
  font-size: 24rpx;
  color: #FF6B8A;
  background: #FFF5F7;
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 500;
  transition: all 0.15s;
}
.rc-tag:active { background: #FF6B8A; color: #fff; transform: scale(0.95); }

.rc-extra {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #F9F9FB;
  border-radius: 16rpx;
}
.rc-extra-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #86868B;
  display: block;
  margin-bottom: 8rpx;
}
.rc-extra-text {
  font-size: 26rpx;
  color: #636366;
  line-height: 1.6;
}

.rc-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}
.rc-actions.secondary { margin-top: 12rpx; }
.rc-act {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #86868B;
  background: #F5F5F7;
  padding: 18rpx 0;
  border-radius: 18rpx;
  transition: all 0.15s;
}
.rc-act:active { background: #E5E5EA; transform: scale(0.97); }
.rc-act.primary {
  color: #FFFFFF;
  background: #FF6B8A;
}
.rc-act.primary:active { background: #E85D7A; }
.rc-act.s {
  color: #636366;
  font-size: 24rpx;
}