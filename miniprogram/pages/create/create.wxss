/* === 创作页 === */

.page { padding: 0 32rpx; position: relative; overflow: hidden; }

/* 顶部主题光晕 */
.theme-glow {
  position: absolute;
  top: -120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 700rpx;
  height: 500rpx;
  pointer-events: none;
  z-index: 0;
  transition: background 0.45s cubic-bezier(0.25,0.1,0.25,1);
}

.hero, .input-card, .tags-scroll, .section, .generate-btn {
  position: relative;
  z-index: 1;
}

/* Hero */
.hero {
  padding: 60rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hero-title {
  font-size: 56rpx;
  font-weight: 200;
  color: #1D1D1F;
  letter-spacing: 12rpx;
  margin-top: 24rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 12rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
}

/* 输入框 */
.input-card {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  transition: border-color 0.4s cubic-bezier(0.25,0.1,0.25,1);
}
.main-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  color: #1D1D1F;
  line-height: 1.7;
  background: transparent;
}
.main-input::placeholder { color: #C7C7CC; }
.input-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 12rpx;
  border-top: 0.5rpx solid #F5F5F7;
}
.if-count { font-size: 22rpx; color: #C7C7CC; }

/* 场景标签 */
.tags-scroll {
  white-space: nowrap;
  margin-bottom: 32rpx;
}
.tag-scene, .tag-hot {
  display: inline-block;
  font-size: 25rpx;
  padding: 12rpx 26rpx;
  border-radius: 100rpx;
  margin-right: 12rpx;
  font-weight: 500;
  transition: all 0.2s;
  background: #FFFFFF;
  color: #636366;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.03);
}
.tag-scene.active {
  background: #FF6B8A;
  color: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(255,107,138,0.25);
}
.tag-hot.active {
  background: #1D1D1F;
  color: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.15);
}
.tag-scene:active, .tag-hot:active { transform: scale(0.95); }
.tag-divider {
  display: inline-block;
  width: 1rpx;
  height: 32rpx;
  background: #E5E5EA;
  margin: 0 6rpx;
  vertical-align: middle;
}

/* 通用 section */
.section { margin-bottom: 32rpx; }

/* 长度卡片 */
.length-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.length-row::-webkit-scrollbar { display: none; }
.length-chip {
  flex: 0 0 148rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1.5rpx solid #EAEAEE;
  transition: all 0.25s cubic-bezier(0.25,0.1,0.25,1);
}
.length-chip.active {
  transform: translateY(-2rpx);
}
.length-chip:active { transform: scale(0.95); }
.lc-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  transition: color 0.3s ease;
}
.lc-hint {
  font-size: 20rpx;
  color: #C7C7CC;
  margin-top: 4rpx;
}
.lc-words {
  font-size: 18rpx;
  color: #C7C7CC;
  margin-top: 6rpx;
}

/* 风格 — 横向滚动 */
.style-scroll {
  white-space: nowrap;
}
.style-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 140rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1.5rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.25,0.1,0.25,1);
}
.style-chip.active {
  transform: translateY(-2rpx);
}
.style-chip:active { transform: scale(0.97); }
.sc-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1D1D1F;
  transition: color 0.3s ease;
}
.sc-desc {
  font-size: 19rpx;
  color: #C7C7CC;
  margin-top: 6rpx;
  transition: color 0.3s ease;
}

/* 高级设置折叠 */
.advanced-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}
.at-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #86868B;
  letter-spacing: 2rpx;
}
.at-arrow {
  font-size: 40rpx;
  color: #C7C7CC;
  font-weight: 200;
  transition: transform 0.25s ease;
}
.at-arrow.open { transform: rotate(90deg); }
.advanced-body {
  padding-top: 16rpx;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 生成按钮 */
.generate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 24rpx;
  margin: 36rpx 0;
  transition: background 0.4s cubic-bezier(0.25,0.1,0.25,1),
              box-shadow 0.4s cubic-bezier(0.25,0.1,0.25,1),
              transform 0.2s ease;
}
.generate-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.gb-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

/* 历史 */
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.history-clear {
  font-size: 26rpx;
  color: #FF6B8A;
  font-weight: 500;
  padding: 8rpx;
}
.history-row {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  transition: background 0.15s;
}
.history-row:active { background: rgba(0,0,0,0.02); }
.hr-prompt {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 450;
}
.hr-time {
  font-size: 24rpx;
  color: #C7C7CC;
  flex-shrink: 0;
  margin-left: 24rpx;
}