/* === 灵感墙 · 马卡龙画廊 3.1 — 动态图 + 流光 === */

page {
  background: #FFFAF5;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  padding: 0 32rpx;
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ========== 背景装饰 ========== */
.decor-circle {
  position: absolute; border-radius: 50%; filter: blur(100rpx);
  opacity: 0.12; pointer-events: none; z-index: 0;
}
.decor-1 {
  width: 500rpx; height: 500rpx; top: -60rpx; right: -100rpx;
  background: radial-gradient(circle, rgba(255,107,138,0.35) 0%, rgba(255,107,138,0) 65%);
}
.decor-2 {
  width: 400rpx; height: 400rpx; bottom: 300rpx; left: -140rpx;
  background: radial-gradient(circle, rgba(52,199,89,0.22) 0%, rgba(52,199,89,0) 65%);
}

/* ========== 浮动 emoji ========== */
.float-emoji {
  position: absolute; z-index: 0; pointer-events: none;
  font-size: 48rpx; opacity: 0;
  animation: floatUp 6s ease-in-out infinite;
}
.f1 { top: 15%; left: 8%; animation-delay: 0s; font-size: 44rpx; }
.f2 { top: 25%; right: 10%; animation-delay: 1.5s; font-size: 38rpx; }
.f3 { top: 55%; left: 5%; animation-delay: 3s; font-size: 42rpx; }
.f4 { top: 70%; right: 8%; animation-delay: 4.5s; font-size: 36rpx; }

@keyframes floatUp {
  0%   { opacity: 0; transform: translateY(0) rotate(0deg) scale(0.8); }
  15%  { opacity: 0.45; }
  50%  { opacity: 0.25; transform: translateY(-80rpx) rotate(15deg) scale(1.1); }
  85%  { opacity: 0.45; }
  100% { opacity: 0; transform: translateY(-160rpx) rotate(30deg) scale(0.8); }
}

.hero, .top-bar, .trending-bar, .hero-card, .section, .bottom-space { position: relative; z-index: 1; }

/* ========== 热榜滚动条 ========== */
.trending-bar {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 24rpx; padding: 16rpx 24rpx;
  background: #FFFFFF; border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  animation: shimmerLine 2.5s ease-in-out infinite;
}
@keyframes shimmerLine {
  0%, 100% { box-shadow: 0 2rpx 12rpx rgba(255,107,138,0.06); }
  50%      { box-shadow: 0 2rpx 18rpx rgba(255,107,138,0.14); }
}
.trending-label {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 24rpx; font-weight: 600; color: #FF6B8A; flex-shrink: 0;
}
.trending-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #FF6B8A;
  animation: dotPulse 1.2s ease-in-out infinite;
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.4; transform: scale(1.6); }
}
.trending-swiper { height: 34rpx; flex: 1; }
.trending-row { display: flex; align-items: center; gap: 10rpx; height: 34rpx; }
.trending-rank {
  font-size: 20rpx; color: #B0B0B8; font-weight: 500; width: 24rpx; text-align: center; flex-shrink: 0;
}
.trending-rank.rank-hot { color: #FF6B8A; font-weight: 700; }
.trending-title { font-size: 25rpx; color: #636366; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.trending-hot { font-size: 20rpx; color: #B0B0B8; flex-shrink: 0; }
.trending-source { font-size: 20rpx; color: #B0B0B8; font-weight: 400; }

/* ========== 顶部 ========== */
.hero { padding: 56rpx 0 24rpx; text-align: center; }
.hero-title { display: block; font-size: 54rpx; font-weight: 200; color: #1D1D1F; letter-spacing: 14rpx; }
.hero-desc { display: block; font-size: 25rpx; color: #999999; margin-top: 8rpx; letter-spacing: 2rpx; }

/* ========== 筛选 + 刷新 ========== */
.top-bar { display: flex; align-items: center; gap: 8rpx; margin-bottom: 22rpx; }
.filter-scroll { white-space: nowrap; display: flex; flex: 1; }
.filter-chip {
  display: inline-flex; align-items: center; gap: 6rpx;
  font-size: 26rpx; color: #8E8E93; padding: 14rpx 26rpx; border-radius: 100rpx;
  margin-right: 12rpx; background: #FFFFFF; box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.25s ease; font-weight: 500;
}
.filter-chip.active { background: #1D1D1F; color: #FFFFFF; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.15); transform: scale(1.04); }
.filter-chip:active { transform: scale(0.95); }

.refresh-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%; background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.refresh-btn:active {
  transform: rotate(180deg) scale(0.9);
  background: #F5F5F7;
}
.refresh-icon { font-size: 34rpx; color: #8E8E93; }

/* ========== 今日精选 Hero Card ========== */
.hero-card {
  margin-bottom: 36rpx; border-radius: 28rpx; padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  transition: all 0.3s ease; position: relative; overflow: hidden;
}
.hero-card:active { transform: scale(0.98); box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1); }

.hero-enter {
  animation: heroSlideIn 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
}
@keyframes heroSlideIn {
  from { opacity: 0; transform: translateY(20rpx) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Hero 光晕脉冲 */
.hero-card::after {
  content: '';
  position: absolute; top: -40rpx; right: -40rpx;
  width: 180rpx; height: 180rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.5) 0%, transparent 70%);
  animation: pulseGlow 3s ease-in-out infinite;
  pointer-events: none;
}
@keyframes pulseGlow {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%      { opacity: 0.8; transform: scale(1.15); }
}

/* Hero 封面 */
.hc-cover {
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
}
.hc-cover-circle {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  animation: coverBounce 4s ease-in-out infinite;
}
@keyframes coverBounce {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25%      { transform: translateY(-6rpx) rotate(3deg); }
  75%      { transform: translateY(4rpx) rotate(-3deg); }
}
.hc-cover-img {
  position: absolute; width: 100%; height: 100%; border-radius: 50%;
  opacity: 0; transition: opacity 0.5s ease;
}
.hc-cover-img.img-loaded { opacity: 1; }
.hc-cover-emoji {
  font-size: 64rpx; position: relative; z-index: 1;
  transition: opacity 0.3s ease;
}
.hc-cover-emoji.emoji-hidden { opacity: 0; }

.hc-badge {
  display: inline-flex; background: rgba(0,0,0,0.8); padding: 8rpx 20rpx;
  border-radius: 100rpx; margin-bottom: 20rpx;
}
.hc-badge-text { font-size: 22rpx; color: #FFFFFF; font-weight: 600; letter-spacing: 1rpx; }
.hc-platform { font-size: 24rpx; color: #636366; font-weight: 500; display: block; margin-bottom: 10rpx; }
.hc-title { font-size: 38rpx; color: #1D1D1F; font-weight: 600; line-height: 1.35; display: block; margin-bottom: 14rpx; }
.hc-preview { font-size: 27rpx; color: #636366; line-height: 1.55; display: block; margin-bottom: 18rpx; }
.hc-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 20rpx; }
.hc-tag { font-size: 22rpx; color: #86868B; background: rgba(255,255,255,0.7); padding: 6rpx 16rpx; border-radius: 100rpx; }
.hc-cta {
  display: flex; align-items: center; justify-content: flex-end;
  font-size: 26rpx; color: #1D1D1F; font-weight: 600; letter-spacing: 1rpx;
}

/* ========== 分区 ========== */
.section { margin-bottom: 40rpx; }
.section-header { margin-bottom: 18rpx; }
.section-title {
  font-size: 26rpx; font-weight: 600; color: #636366;
  letter-spacing: 2rpx; display: block;
}

/* ========== 分区卡片行 ========== */
.sec-row { display: flex; gap: 14rpx; margin-bottom: 14rpx; }

.sec-card {
  border-radius: 22rpx; padding: 24rpx;
  box-shadow: 0 2rpx 14rpx rgba(0,0,0,0.04);
  transition: all 0.2s ease; display: flex; flex-direction: column; position: relative; overflow: hidden;
}
.sec-card:active { transform: scale(0.975); box-shadow: 0 6rpx 22rpx rgba(0,0,0,0.08); }

/* shimmer 呼吸光 */
.shimmer::before {
  content: '';
  position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.35) 50%, transparent 100%);
  animation: shimmerSweep 3s ease-in-out infinite;
  pointer-events: none; z-index: 0;
}
@keyframes shimmerSweep {
  0%   { left: -100%; }
  100% { left: 200%; }
}

/* 分区卡片入场（错峰） */
.sec-enter {
  animation: cardSlideUp 0.45s cubic-bezier(0.25, 0.1, 0.25, 1) both;
}
.sec-row:nth-child(1) .sec-enter { animation-delay: 0.05s; }
.sec-row:nth-child(2) .sec-enter { animation-delay: 0.15s; }
.section:nth-child(3) .sec-enter { animation-delay: 0.08s; }
.section:nth-child(4) .sec-enter { animation-delay: 0.18s; }
.section:nth-child(5) .sec-enter { animation-delay: 0.12s; }

@keyframes cardSlideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ====== 封面图片通用 ====== */
.sc-cover { display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx; }
.sc-cover-circle, .sc-cover-circle-sm, .sc-cover-circle-xs {
  border-radius: 50%; position: relative; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.sc-cover-circle {
  width: 88rpx; height: 88rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.sc-cover-circle-sm { width: 72rpx; height: 72rpx; }
.sc-cover-circle-xs { width: 56rpx; height: 56rpx; }

/* 封面图片 */
.sc-cover-img {
  position: absolute; width: 100%; height: 100%; border-radius: 50%;
  opacity: 0; transition: opacity 0.4s ease;
}
.sc-cover-img.img-loaded { opacity: 1; }

.sc-cover-emoji { font-size: 44rpx; position: relative; z-index: 1; transition: opacity 0.35s ease; }
.sc-cover-emoji.emoji-hidden { opacity: 0; }
.sc-cover-emoji-sm { font-size: 36rpx; }
.sc-cover-emoji-xs { font-size: 32rpx; }

/* 小卡封面 */
.sc-cover-sm { margin-bottom: 12rpx; }

/* 迷你卡封面 */
.sc-cover-xs { margin-bottom: 10rpx; }

/* ====== 大卡片 ====== */
.sec-card-large { flex: 0 0 58%; }
.sec-card-large .sc-title { font-size: 30rpx; margin-bottom: 10rpx; }
.sec-card-large .sc-preview {
  font-size: 24rpx; color: #86868B; line-height: 1.5;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 14rpx;
}
.sec-card-large .sc-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.sec-card-large .sc-tag {
  font-size: 20rpx; color: #999; background: rgba(255,255,255,0.6);
  padding: 4rpx 12rpx; border-radius: 100rpx;
}

/* ====== 小卡片 ====== */
.sec-card-small { flex: 1; }
.sec-card-small .sc-title {
  font-size: 26rpx; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}

/* ====== 迷你卡片 ====== */
.sec-card-mini { flex: 1; padding: 22rpx; }
.sec-card-mini .sc-title {
  font-size: 25rpx; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

.sc-product { font-size: 22rpx; font-weight: 600; color: #1D1D1F; display: block; margin-bottom: 6rpx; opacity: 0.7; position: relative; z-index: 1; }
.sc-title { color: #1D1D1F; font-weight: 500; display: block; position: relative; z-index: 1; }
.sc-preview { position: relative; z-index: 1; }
.sc-tags { position: relative; z-index: 1; }

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 100;
  display: flex; align-items: flex-end; justify-content: center;
  animation: maskIn 0.2s ease;
}
@keyframes maskIn { from { opacity: 0; } to { opacity: 1; } }
.modal-card {
  width: 100%; max-height: 78vh; background: #FFFFFF;
  border-radius: 36rpx 36rpx 0 0; padding: 36rpx 40rpx 70rpx;
  overflow-y: auto; animation: slideUp 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22rpx; }
.modal-plat { font-size: 26rpx; color: #636366; font-weight: 500; }
.modal-close { font-size: 34rpx; color: #B0B0B8; padding: 8rpx; font-weight: 300; }
.modal-product { font-size: 26rpx; font-weight: 600; color: #1D1D1F; display: block; margin-bottom: 10rpx; }
.modal-title { font-size: 34rpx; color: #1D1D1F; font-weight: 500; line-height: 1.45; display: block; }
.modal-divider { height: 0.5rpx; background: #F0F0F5; margin: 26rpx 0; }
.modal-content { font-size: 29rpx; color: #3A3A3C; line-height: 1.9; display: block; white-space: pre-line; }
.modal-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-top: 24rpx; }
.modal-tag { font-size: 23rpx; color: #FF6B8A; background: #FFF5F7; padding: 8rpx 18rpx; border-radius: 100rpx; }
.modal-actions { display: flex; gap: 16rpx; margin-top: 36rpx; }
.m-action-primary {
  flex: 1; text-align: center; font-size: 30rpx; font-weight: 600;
  color: #FFFFFF; background: #FF6B8A; padding: 24rpx 0; border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(255,107,138,0.3); transition: all 0.15s ease;
}
.m-action-primary:active { background: #E85D7A; transform: scale(0.97); }
.m-action-secondary {
  text-align: center; font-size: 30rpx; font-weight: 600;
  color: #FF6B8A; background: #FFF0F3; padding: 24rpx 40rpx; border-radius: 20rpx;
  transition: all 0.15s ease;
}
.m-action-secondary:active { background: #FFE5EA; transform: scale(0.97); }

/* ========== 底部 ========== */
.bottom-space { height: 100rpx; }