/* === 作品页 === */

.page { padding: 0 32rpx; }

/* 加载状态 */
.loading-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #86868B;
  font-weight: 400;
}

/* 错误 */
.error-msg {
  margin-top: 100rpx;
  padding: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #D43D3D;
  background: #FFF5F5;
  border-radius: 24rpx;
}
.error-retry {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #FF6B8A;
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 结果头 */
.result-header {
  padding: 32rpx 0 24rpx;
}
.rh-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
}
.rh-sub {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 8rpx;
  display: block;
}

/* 继续创作 */
.continue-section {
  margin-top: 40rpx;
  margin-bottom: 24rpx;
}
.continue-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.continue-chip {
  padding: 18rpx 32rpx;
  border-radius: 100rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  font-size: 26rpx;
  color: #636366;
  font-weight: 500;
  transition: all 0.2s;
}
.continue-chip:active {
  background: #F9F9FB;
  transform: scale(0.97);
}

/* 返回 */
.back-btn {
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #FF6B8A;
  font-weight: 500;
}