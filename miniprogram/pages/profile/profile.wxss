/* === 我的页 === */

.page { padding: 0; }

/* 头像区 */
.avatar-section {
  padding: 80rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar { margin-bottom: 20rpx; }
.avatar-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,107,138,0.15), rgba(196,166,255,0.15));
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-inner {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FF6B8A;
}
.avatar-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.avatar-slogan {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 统计 */
.stats-card {
  display: flex;
  margin: 0 32rpx 24rpx;
  padding: 32rpx 0;
}
.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 48rpx;
  font-weight: 200;
  color: #1D1D1F;
}
.stat-label {
  font-size: 24rpx;
  color: #86868B;
  margin-top: 4rpx;
}
.stat-divider {
  width: 0.5rpx;
  background: #F0F0F5;
}

/* 设置组 */
.setting-group {
  margin: 0 32rpx 24rpx;
  padding: 8rpx 0;
}

/* 收藏预览 */
.section {
  padding: 0 32rpx;
}
.collection-item {
  padding: 28rpx 32rpx;
  margin-bottom: 12rpx;
  transition: all 0.15s;
}
.collection-item:active { background: #F9F9FB; }
.ci-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ci-preview {
  font-size: 25rpx;
  color: #86868B;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== 子视图通用 ===== */
.sub-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #FBFBFD;
}
.sub-back {
  display: flex;
  align-items: center;
  padding: 8rpx;
}
.sub-back-arrow {
  font-size: 44rpx;
  color: #FF6B8A;
  font-weight: 200;
  line-height: 1;
  margin-right: 4rpx;
}
.sub-back-text {
  font-size: 28rpx;
  color: #FF6B8A;
}
.sub-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.empty-state {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}
.empty-text {
  font-size: 28rpx;
  color: #C7C7CC;
}

.sub-list {
  padding: 0 32rpx;
}

.sub-item {
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  transition: all 0.15s;
}
.sub-item:active { background: #F9F9FB; }

.si-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 10rpx;
}
.si-body {
  font-size: 26rpx;
  color: #636366;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 14rpx;
}
.si-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.si-tag {
  font-size: 22rpx;
  color: #FF6B8A;
  background: rgba(255,107,138,0.08);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.si-prompt {
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 500;
  display: block;
  line-height: 1.5;
}
.si-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
.si-time {
  font-size: 24rpx;
  color: #C7C7CC;
}
.si-btns {
  display: flex;
  gap: 24rpx;
}
.si-btn {
  font-size: 26rpx;
  color: #FF6B8A;
  font-weight: 500;
  padding: 4rpx 8rpx;
}
.si-btn-del {
  color: #C7C7CC;
}
.si-tag-s {
  font-size: 22rpx;
  color: #86868B;
  background: #F5F5F7;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}