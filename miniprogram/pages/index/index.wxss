.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin: 60rpx 0 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff2442;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.input-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.input {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.btn {
  background: #ff2442;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.btn[disabled] {
  background: #ff8a9a;
  color: #fff;
}

.btn-test {
  background: #fff;
  color: #666;
  font-size: 26rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.result-section {
  margin-top: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 16rpx;
}

.title-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
}

.title-item {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-item:last-child {
  border-bottom: none;
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.content-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
}

.content-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.copy-btn {
  align-self: flex-end;
  font-size: 24rpx;
  color: #ff2442;
  background: #fff;
  border: 1rpx solid #ff2442;
  border-radius: 8rpx;
  padding: 8rpx 24rpx;
  margin-top: 16rpx;
}

.error-box {
  margin-top: 30rpx;
  background: #fff2f2;
  border-radius: 12rpx;
  padding: 24rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff2442;
}